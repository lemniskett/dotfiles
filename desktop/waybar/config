{
    "layer": "top",
    "position": "bottom",
    "height": 30,
    "modules-left": ["clock"],
    "modules-center": ["sway/workspaces"],
    "modules-right": ["tray", "idle_inhibitor", "cpu", "custom/ping", "network", "pulseaudio", "battery", "custom/powermenu"],
    "sway/window": {
        "max-length": 50
    },
    "sway/mode": {
        "tooltip": false
    },
    "sway/workspaces": {
        "all-outputs": true,
        "persistent_workspaces": {
        "1": [],
        "2": [],
        "3": [],
        "4": [],
        "5": [],
        "6": [],
        "7": [],
        "8": [],
        "9": []
        }
    },
    "custom/ping": {
        "exec": "$HOME/.config/waybar/scripts/ping.sh",
        "interval": 3,
        "tooltip": false,
        "format": "{} ms пІД"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "tooltip": false,
        "format-icons": {
            "activated": "пГі",
            "deactivated": "пГі"
        }
    },
    "cpu": {
        "format": "{usage}% пЛЫ",
        "interval": "1",
        "tooltip": false
    },
    "custom/kernel": {
        "exec": "uname -r",
        "interval": "once",
        "tooltip": false
    },
    "tray": {
        "spacing": 5,
        "icon-size": 14,
        "tooltip": false
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 20,
            "critical": 10
        },
        "format": "{capacity}% пХЄ",
        "format-charging": "{capacity}% пЦД",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        //"format-icons": ["пЙД ", "пЙГ ", "пЙГ ", "пЙВ ", "пЙВ ", "пЙБ ", "пЙБ ", "пЙА "],
        "tooltip": false,
	"on-click": "footclient htop"
    },
    "custom/powermenu": {
        "on-click": "nwgbar -b 32343dff",
        "format": "вПї",
        "tooltip": false
    },
    "custom/assistant": {
        "exec": "assistant",
	"interval": 20,
    "format": "п°†  {}",
	"tooltip": false
    },
    "clock": {
        "format": "пАЧ  {:%a, %d %b %H:%M}",
        "tooltip": false,
	"on-click": "footclient calcurse"
    },
    "pulseaudio": {
        //"scroll-step": 1,
        "format": "{volume}% {icon}",
        "format-bluetooth": "{volume}% {icon}пКФ",
        "format-muted": "пА¶",
        "format-icons": {
            "headphones": "пА•",
            "handsfree": "пЦР",
            "headset": "пЦР",
            "phone": "пВХ",
            "portable": "пВХ",
            "car": "пЖє",
            "default": ["пАІ", "пА®"]
        },
        "tooltip": false,
        "on-click": "pavucontrol"
    },
    "network": {
        "format-wifi": "{signalStrength}% пЗЂ",
        "format-ethernet": "Wired пГБ",
        "format-disconnected": " вЪ†",
        "tooltip": false,
	"on-click": "footclient nmtui"
    }
}
