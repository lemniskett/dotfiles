{
    "layer": "top",
    "position": "top",
    "height": 30,
    "modules-left": ["custom/launcher", "sway/window"],
    "modules-center": ["clock"],
    "modules-right": ["tray", "idle_inhibitor", "cpu", "custom/ping", "network", "pulseaudio", "battery", "custom/powermenu"],
    "sway/window": {
        "format": "{}",
        "max-length": 50
    },
    "custom/ping": {
        "exec": "$HOME/.config/waybar/scripts/ping.sh",
        "interval": 3,
        "tooltip": false,
        "format": "{} ms 龍"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "tooltip": false,
        "format-icons": {
            "activated": "",
            "deactivated": ""
        }
    },
    "cpu": {
        "format": "{usage}% ",
        "interval": "1",
        "tooltip": false
    },
    "tray": {
        "spacing": 5,
        "icon-size": 14,
        "tooltip": false
    },
    "battery": {
        "states": {
            "warning": 20,
            "critical": 10
        },
        "format": "{capacity}% ",
        "format-charging": "{capacity}% ",
        "tooltip": false,
	    "on-click": "footclient htop"
    },
    "custom/powermenu": {
        "on-click": "~/.config/sway/scripts/powermenu.sh",
        "format": "⏻",
        "tooltip": false
    },
    "clock": {
        "format": "{:%a, %d %b %H:%M}",
        "tooltip": false,
	    "on-click": "footclient calcurse"
    },
    "pulseaudio": {
        "format": "{volume}% {icon}",
        "format-bluetooth": "{volume}% {icon}",
        "format-muted": "",
        "format-icons": {
            "headphones": "",
            "handsfree": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": [""]
        },
        "tooltip": false,
        "on-click": "pavucontrol"
    },
    "network": {
        "format-wifi": "{signalStrength}% ",
        "format-ethernet": "Wired ",
        "format-disconnected": " ⚠",
        "tooltip": false,
	    "on-click": "footclient nmtui"
    },
    "custom/launcher": {
        "on-click": "~/.config/sway/scripts/launcher.sh",
        "format": "異 Launcher"
    }
}
